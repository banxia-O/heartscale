# ============================================================
# heartscale — 配置文件示例
# 使用方式：复制为 config.yaml，填入你的配置后运行
# ============================================================

# -----------------------------------------------------------
# 日记目录（放你的 .md / .txt 日记文件的文件夹）
# -----------------------------------------------------------
diary:
  dir: "~/Documents/diary"          # 日记文件夹路径，支持 ~ 展开
  extensions: [".md", ".txt"]       # 识别的文件扩展名

# -----------------------------------------------------------
# 输出文件路径
# -----------------------------------------------------------
output:
  heart_md: "~/.hermes/HEART.md"         # 最终心境文件，注入 agent identity
  limbic_jsonl: "~/.hermes/limbic.jsonl" # 中间层结构化记忆
  backup_dir: "~/.hermes/backups"        # 备份目录
  backup_keep: 4                         # 保留最近几个备份版本

# -----------------------------------------------------------
# 数据库
# -----------------------------------------------------------
database:
  path: "~/.hermes/heartscale.db"   # SQLite 数据库文件路径

# -----------------------------------------------------------
# 渲染语言（zh = 中文，en = English）
# HEART.md 的自然语言段落会用这个语言生成
# -----------------------------------------------------------
language: "zh"

# -----------------------------------------------------------
# Embedding 提供商（用于向量检索，Phase 2）
# provider 填 "openai" 可对接任何 OpenAI 兼容格式的 API
# -----------------------------------------------------------
embedding:
  provider: "openai"
  model: "text-embedding-3-small"
  api_key_env: "HEARTSCALE_EMBEDDING_KEY"   # 环境变量名，存放你的 API Key
  base_url: ""      # 留空 = 官方 OpenAI；填入其他地址可接硅基流动等兼容 API
  dimension: 1024   # 向量维度，需与模型匹配

# -----------------------------------------------------------
# 语义判断 LLM（情感抽取 + HEART.md 渲染时调用）
# -----------------------------------------------------------
judge:
  provider: "openai"
  model: "gpt-4o-mini"
  api_key_env: "HEARTSCALE_JUDGE_KEY"       # 环境变量名，存放你的 API Key
  base_url: ""      # 留空 = 官方 OpenAI；填入其他地址可接 Deepseek 等兼容 API

# -----------------------------------------------------------
# 自动调度时间（供 heartscale scheduler 命令使用）
# -----------------------------------------------------------
schedule:
  # 每日日记抽取时间（HH:MM，24小时制）
  # 必须晚于日记写入完成的时间。
  # 例：若你的日记在 23:59 写完，将此项设为次日 "00:05"，保留 5 分钟缓冲。
  daily_time: "00:05"
  weekly_day: "sunday"   # 每周压缩处理的星期几
  monthly_day: 1         # 每月处理的日期（1 = 每月1日）
